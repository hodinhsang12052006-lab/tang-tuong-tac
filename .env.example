# -------------------------------------------------------------
# CẤU HÌNH BIẾN MÔI TRƯỜNG DỰ ÁN SMM PANEL BITPAWNETWORK
# Sao chép tệp này thành '.env' và điền thông số thực tế của bạn
# -------------------------------------------------------------

# Cổng máy chủ Express chạy cục bộ
PORT=3000

# Đường dẫn kết nối tới cơ sở dữ liệu MongoDB (Local hoặc MongoDB Atlas Cloud)
MONGO_URI=mongodb://127.0.0.1:27017/bitpawnetwork

# Khóa bí mật dùng để ký chữ ký số JWT token (nên sử dụng chuỗi dài ngẫu nhiên)
JWT_SECRET=SUPER_SECRET_KEY_BITPAW_NETWORK_2026

# Khóa API để gọi lệnh sang API nhà cung cấp gốc (SMM Provider API Key)
PROVIDER_API_KEY=YOUR_MAIN_SMM_PROVIDER_API_KEY
